<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.getarcaneapp.ios.mobile</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>arcane-mobile</string>
			</array>
		</dict>
	</array>
	<!-- ATS exception (App Review justification): Arcane connects to user-controlled,
	     self-hosted servers that are frequently reachable only over plain HTTP —
	     LAN IPs, VPN/Tailscale addresses, and other private hosts where TLS is not
	     available. NSAllowsLocalNetworking alone would break VPN/remote-HTTP setups,
	     so arbitrary loads is required. The app never talks to third-party services. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Arcane needs local network access to connect to self-hosted Arcane servers on your network.</string>
	<key>UIApplicationShortcutItems</key>
	<array>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>chart.bar.fill</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Dashboard</string>
			<key>UIApplicationShortcutItemType</key>
			<string>arcane.shortcut.dashboard</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>cube.box.fill</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Containers</string>
			<key>UIApplicationShortcutItemType</key>
			<string>arcane.shortcut.containers</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemIconSymbolName</key>
			<string>square.stack.3d.up.fill</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Projects</string>
			<key>UIApplicationShortcutItemType</key>
			<string>arcane.shortcut.projects</string>
		</dict>
	</array>
</dict>
</plist>
